# --- App (apps/web) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (Auth + Postgres + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection strings (Supabase → Settings → Database → Connection string).
# App runtime (serverless / Vercel): Transaction pooler, port 6543.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Migrations (drizzle-kit): Session pooler / direct connection, port 5432.
# If the password contains URL-reserved characters (@ : / ? # !), percent-encode them (@ -> %40, ! -> %21, ...).
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Trigger.dev (background jobs) ---
# Secret key from Trigger.dev dashboard → Project → API keys (use the DEV key locally).
TRIGGER_SECRET_KEY=
# Project ref (proj_…) from Trigger.dev → Project settings. Used by trigger.config.ts.
TRIGGER_PROJECT_REF=
# Dev: run `npm run trigger:dev -w @app/web` (runs tasks against your Trigger.dev dev environment)

# --- AI generators (Realms generator pipeline) ---
# Anthropic API key from console.anthropic.com. Required for AI generation
# (NPC / Region generators); the app otherwise runs without it.
ANTHROPIC_API_KEY=
# Optional model override (defaults to the @app/llm DEFAULT_MODEL snapshot).
ANTHROPIC_MODEL=

# --- Tutorial onboarding (TUT-1, #177) ---
# Launch gate: `off` (default, no redirect) | `first_run` (new users → /tutorial splash).
TUTORIAL_GATE=off

# --- Observability (optional in local dev) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- WebSocket sync server (@app/ws-server, Tier 4 multiplayer #14) ---
# Web app → WS server URL (browser-exposed). Defaults to ws://localhost:1234.
NEXT_PUBLIC_WS_URL=ws://localhost:1234
# The WS server verifies Supabase session tokens against the project's public
# JWKS, derived from NEXT_PUBLIC_SUPABASE_URL (or SUPABASE_URL) above. Projects
# on the new JWT signing keys (ECC P-256 / RSA) need no extra config here.
# Optional legacy fallback — set ONLY if you still have HS256-signed tokens
# during the signing-key migration (Dashboard → Settings → JWT Keys → Legacy
# JWT Secret):
# SUPABASE_JWT_SECRET=
# Optional: override the WS server listen port (default 1234).
# WS_PORT=1234
