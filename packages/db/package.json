{
  "name": "@app/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "dotenv -e ../../.env.local --no-expand -- drizzle-kit generate",
    "migrate": "dotenv -e ../../.env.local --no-expand -- drizzle-kit migrate",
    "ingest:open5e": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e.ts"
  },
  "dependencies": {
    "@app/config": "*",
    "drizzle-orm": "^0.43.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
