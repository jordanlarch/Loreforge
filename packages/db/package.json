{
  "name": "@app/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./traits": "./src/ingest/srd-trait-descriptions.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate": "dotenv -e ../../.env.local --no-expand -- drizzle-kit generate",
    "migrate": "dotenv -e ../../.env.local --no-expand -- drizzle-kit migrate",
    "ingest:open5e": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e.ts",
    "ingest:open5e-creatures": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e-creatures.ts",
    "ingest:open5e-items": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e-items.ts",
    "ingest:open5e-backgrounds": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e-backgrounds.ts",
    "ingest:open5e-feats": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e-feats.ts",
    "ingest:open5e-rules": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e-rules.ts",
    "ingest:open5e-advanced-rules": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/ingest-open5e-advanced-rules.ts",
    "seed:character-options": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/seed-character-options.ts",
    "seed:toolbox-traps": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/seed-toolbox-traps.ts",
    "seed:toolbox-poisons": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/seed-toolbox-poisons.ts",
    "srd-audit:db": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/srd-audit-db.ts",
    "purge:characters": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/purge-all-characters.ts",
    "generate:spell-registry": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/generate-spell-registry.ts",
    "backfill:plot-hooks-quests": "dotenv -e ../../.env.local --no-expand -- tsx src/scripts/backfill-plot-hooks-quests.ts"
  },
  "dependencies": {
    "@app/config": "*",
    "@app/engine": "*",
    "drizzle-orm": "^0.43.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
