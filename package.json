{
  "name": "loreforge",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @app/web",
    "dev:ws": "npm run dev -w @app/ws-server",
    "build": "npm run build -w @app/web",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "test": "npm run test -ws --if-present",
    "db:generate": "npm run generate -w @app/db",
    "db:migrate": "npm run migrate -w @app/db",
    "ingest:open5e": "npm run ingest:open5e -w @app/db",
    "seed:character-options": "npm run seed:character-options -w @app/db",
    "backfill:embeddings": "npm run backfill:realms -w @app/memory"
  },
  "overrides": {
    "import-in-the-middle": "3"
  },
  "engines": {
    "node": ">=20"
  }
}
