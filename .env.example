# --- App (apps/web) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (Auth + Postgres + Storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection (Supabase → Settings → Database → Connection string, use "Transaction" pooler for serverless)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Trigger.dev (background jobs) ---
# Secret key from Trigger.dev dashboard → Project → API keys (use the DEV key locally).
TRIGGER_SECRET_KEY=
# Project ref (proj_…) from Trigger.dev → Project settings. Used by trigger.config.ts.
TRIGGER_PROJECT_REF=
# Dev: run `npm run trigger:dev -w @app/web` (runs tasks against your Trigger.dev dev environment)

# --- Observability (optional in local dev) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Node services (P2+; skeleton only in P0) ---
# WS_SERVER_URL=ws://localhost:3001
